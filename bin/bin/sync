#!/bin/bash

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
CONFIG_FILE="$SCRIPT_DIR/sync.yml"

# If arguments are provided, use old behavior (direct rclone passthrough)
if [ $# -gt 0 ]; then
    rclone sync --progress "$@"
    exit $?
fi

# Check if config file exists
if [ ! -f "$CONFIG_FILE" ]; then
    echo "Error: Config file not found at $CONFIG_FILE"
    exit 1
fi

# Check if yq is installed for YAML parsing
if ! command -v yq &> /dev/null; then
    echo "Error: yq is required for parsing YAML config. Install with: brew install yq"
    exit 1
fi

# Read remote from config
REMOTE=$(yq eval '.remote' "$CONFIG_FILE")

if [ -z "$REMOTE" ] || [ "$REMOTE" = "null" ]; then
    echo "Error: 'remote' not defined in $CONFIG_FILE"
    exit 1
fi

echo "Starting sync to $REMOTE..."
echo

# Get number of directories
DIR_COUNT=$(yq eval '.directories | length' "$CONFIG_FILE")

# Iterate through each directory mapping
for ((i=0; i<DIR_COUNT; i++)); do
    LOCAL_DIR=$(yq eval ".directories[$i].local" "$CONFIG_FILE")
    REMOTE_PATH=$(yq eval ".directories[$i].remote" "$CONFIG_FILE")

    # Expand ~ to home directory
    expanded_dir="${LOCAL_DIR/#\~/$HOME}"

    if [ -d "$expanded_dir" ]; then
        echo "Syncing: $expanded_dir → $REMOTE/$REMOTE_PATH"
        rclone sync --progress "$expanded_dir" "$REMOTE/$REMOTE_PATH"
        echo
    else
        echo "Skipping: $expanded_dir (does not exist)"
    fi
done

echo "Sync complete!"
